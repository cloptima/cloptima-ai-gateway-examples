# The one credential every example needs (ai:admin + ai:write + ai:read
# scope). Each example mints its own policy, binding, and virtual key using
# this key - nothing else needs to be pre-provisioned. The gateway URL is
# already built in - you don't need to know or set it.
CLOPTIMA_AI_ADMIN_KEY=clop_pat_...

# Only needed for src/examples/byok.mjs - your own OpenAI-compatible provider
# API key, used to demonstrate routing your own credential through Cloptima's
# governance/attribution/telemetry layer.
PROVIDER_API_KEY=
